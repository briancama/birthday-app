<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Dashboard - Brian's Birthday Zone</title>
    <link rel="icon" type="image/png" href="/images/favicon.jpg" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/submissions.css" />
    <link rel="stylesheet" href="/css/components/event-card.css" />
    <link rel="stylesheet" href="/css/components/achievements.css" />

    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
  </head>

  <body>
    <!-- Server-rendered Navigation -->
      <% const navLocal = Object.assign({}, (typeof navData !== 'undefined' ? navData : {}), { pageTitle: 'Dashboard' }); %>
      <%- include('partials/navigation', { navData: navLocal }) %>
    <div class="container">
      <!-- Scrolling Marquee -->
      <marquee behavior="scroll" direction="left" scrollamount="6">
        *** WELCOME TO THE BIRTHDAY CHALLENGE ZONE<span id="marqueeUsername" style="opacity: 0"></span>! *** Check out the event info for details, submit your challenges, and get ready to party! ***
      </marquee>
      <div class="section" id="personalStatsSection" style="display: none">
        <h2 class="text-shadow-light">YOUR STATS</h2>
        <div id="personalStats">
          <div class="stats-grid">
            <div class="stat-box">
              <img src="/images/matrix.gif" alt="" class="stat-box-bg" />
              <div>
                <div class="stat-label">YOUR RANK</div>
                <div class="stat-value" data-stat="rank">-</div>
              </div>
            </div>
            <div class="stat-box">
              <img src="/images/matrix.gif" alt="" class="stat-box-bg" />
              <div>
                <div class="stat-label">TOTAL POINTS</div>
                <div class="stat-value" data-stat="total-points">-</div>
              </div>
            </div>
            <div class="stat-box">
              <img src="/images/matrix.gif" alt="" class="stat-box-bg" />
              <div>
                <div class="stat-label">CHALLENGES</div>
                <div class="stat-value" data-stat="challenges">-</div>
              </div>
            </div>
            <div class="stat-box">
              <img src="/images/matrix.gif" alt="" class="stat-box-bg" />
              <div>
                <div class="stat-label">BRODOWN</div>
                <div class="stat-value" data-stat="competition-points">-</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Cocktail Competition Section -->
      <div class="section text-center" style="display: flex; flex-direction: column; min-height: 377px; align-items: center">
        <h2 class="text-shadow-light">
          <span><img class="icon-gif icon-gif--lg icon-gif--with-text" src="/images/cocktail_stirrer.gif" alt="Cocktail Icon" />COCKTAIL COMPETITION<img class="icon-gif icon-gif--lg icon-gif--with-text" src="/images/cocktail_stirrer.gif" alt="Cocktail Icon"/></span>
        </h2>
        <p style="margin: 0rem auto 1.5rem; max-width: 600px">Mix your best cocktail and compete! Check the rubric for judging criteria, and when voting opens, rate everyone's creations.</p>
        <a href="/cocktail-rubric" class="btn btn-tertiary" style="min-width: 280px; margin-bottom: 0.75rem;" target="_blank">VIEW RUBRIC</a>
        <button id="registerCocktailBtn" class="btn btn-primary cocktail-button-fade-in" style="min-width: 280px; margin-bottom: 0.75rem; opacity: 0">REGISTER COCKTAIL</button>
        <div id="cocktailJudgingLink" style="display: none">
          <a href="/cocktail-judging" class="btn btn-secondary" style="min-width: 280px">JUDGE COCKTAILS NOW</a>
        </div>
      </div>

      <!-- RSVP'd Events Section -->
      <div class="section">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
          <h2 class="text-shadow-light" style="margin-bottom: 0">YOUR EVENTS</h2>
          <a href="/event-info.html" class="dashboard-events-link" style="font-family: Arial; font-size: 1em; text-decoration: underline; color: var(--accent-color); font-weight: bold; margin-left: 1em;">See All Events</a>
        </div>
        <ul id="userEventsSection" style="padding: 0"></ul>
      </div>

      <!-- Flame Divider -->
      <div class="flame-divider">
        <img src="/images/flame_transparent.gif" alt="Flame Divider" onerror="this.style.display = 'none'" />
      </div>

      <div class="section">
        <h2 class="text-shadow-light">YOUR CHALLENGES <img src="/images/flame.gif" class="icon-gif icon-gif--with-text" /></h2>
        <div id="challengesList" class="challenge-list"></div>
      </div>

      <!-- Achievements Section (hidden until user has awards) -->
      <div class="section" id="achievementsSection">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
          <h2 class="text-shadow-light" style="margin-bottom: 0">ACHIEVEMENTS</h2>
          <div class="achievements-counter" id="achievementsCounter" style="font-size: 12px; font-weight: bold; color: var(--accent-color)"></div>
        </div>
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
          <div id="achievementsLegend" class="hide-desktop" style="font-size: 10px; color: #666">Click for details</div>
        </div>
        <div id="achievementsList" class="achievements-grid" style="padding-top: 8px"></div>
      </div>
    </div>

    <script type="module">
      import { DashboardPage } from "/js/pages/dashboard.js";

      (async () => {
        try {
          const page = new DashboardPage();
          await page.init();
        } catch (err) {
          console.error("Dashboard initialization failed:", err);
        }
      })();
    </script>

    <bottom-menu></bottom-menu>
    <script type="module" src="/js/components/bottom-menu.js"></script>
  </body>
</html>
