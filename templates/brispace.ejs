<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BriSpace - A Place for Friends</title>
    <link rel="icon" type="image/png" href="/images/favicon.jpg" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/myspace.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/brispace-home.css" />
    <link rel="stylesheet" href="/css/components/user-display.css" />
    <link rel="stylesheet" href="/css/components/login-signup.css" />

    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
  </head>
  <body class="myspace" data-auth="<%= !!currentUser %>">
    <%- include('partials/navigation', { navData: (typeof navData !== 'undefined' ? navData : {}) })
    %>
    <main class="myspace-container full-width-content">
      <div class="container myspace-layout">
        <div class="myspace-main">
          <!-- Hero/Intro Section -->
          <section class="myspace-section">
            <h3 class="myspace-section-alt-header">Welcome to BriSpace</h3>
            <div class="brispace-intro-box">
              <p>
                BriSpace is a place for friends, nostalgia, and self-expression. Create your
                profile, connect with others, and relive the best of the 2000s internet. Whether
                you're here to share your latest adventures, show off your old school bling, or just
                hang out and get pwned by some bomb dot com memes, BriSpace is your space.
                <p>When you're here you're family, and trust me we're eating good in the neighborhood.</p>
                <p class="text-micro">I want my baby back, baby back, baby back.</p>
              </p>
            </div>
          </section>

          <!-- Brian's Newest Friends -->
          <% if (latestUsers && latestUsers.length > 0) { %>
          <section class="myspace-section brispace-new-friends">
            <h3 style="margin-bottom: 0">Brian's newest friends</h3>
            <div class="brispace-friends-list">
              <% latestUsers.forEach(function(user) { %> <%- include('partials/user-display', {
              user: user }) %> <% }); %>
            </div>
            <div class="brispace-browse-link">
              <a href="/browse">Browse all &rarr;</a>
            </div>
          </section>
          <% } %>
        </div>
        <!-- Login/Signup or Welcome -->
        <aside class="myspace-sidebar brispace-auth">
          <% if (!currentUser) { %>
          <div id="loginSignupContainer"></div>
          <% } else { %>
          <div class="login-signup-form">
            <h3>
              Welcome back,
              <%= currentUser.display_name || 'friend' %>!
            </h3>
            <a href="/users/<%= currentUser.username %>"
              >Go to your profile</a
            >
          </div>
          <% } %>
        </aside>
      </div>
    </main>

    <footer class="myspace-footer full-width-content">
      <div class="footer-links">
        <a href="/about">About</a> | <a href="/privacy">Privacy</a> |
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-copy">&copy; 2004 BriSpace. All rights reserved.</div>
    </footer>
    <script type="module">
      import { createLoginSignupForm } from "/js/components/login-signup.js";
      import { BrispacePage } from "/js/pages/brispace.js";
      const page = new BrispacePage();
      await page.init();
      const isAuthenticated = document.body.dataset.auth === "true";
      if (!isAuthenticated) {
        const container = document.getElementById("loginSignupContainer");
        if (container) {
          const form = createLoginSignupForm({
            onSuccess: () => {
              window.location.href = "/";
            },
          });
          container.appendChild(form);
        }
      }
    </script>
  </body>
</html>
