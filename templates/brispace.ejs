<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BriSpace - A Place for Friends</title>
    <link rel="icon" type="image/png" href="/images/brispace_favicon.png" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/myspace.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/brispace-home.css" />
    <link rel="stylesheet" href="/css/components/user-display.css" />
    <link rel="stylesheet" href="/css/components/login-signup.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&display=swap"
      rel="stylesheet"
    />

    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
  </head>
  <body class="myspace <%= currentUser ? 'logged-in' : 'logged-out' %>" data-auth="<%= !!currentUser %>">
    <%- include('partials/navigation-visitor', { navData: (typeof navData !== 'undefined' ? navData : {}) })
    %>
    <main class="myspace-container full-width-content">
      <div class="container myspace-layout">
        <div class="myspace-main">
          <!-- Hero/Intro Section -->
          <section class="myspace-section">
            <h3 class="myspace-section-alt-header">Welcome to BriSpace</h3>
            <div class="brispace-intro-box">
              <p>
                BriSpace is a place for friends, nostalgia, and self-expression. Create your profile,
                connect with others, and relive the best of the 2000s internet. Whether
                <span data-ytmnd="Y" class="ytmnd-letter">y</span>ou're here to share your latest adventures,
                <span data-ytmnd="T" class="ytmnd-letter">t</span>o show off your old school bling, or just hang
                out and get pwned by some bomb dot com <span data-ytmnd="M" class="ytmnd-letter">m</span>emes, BriSpace is your
                space.
                <p>When you're here you're family, and <span data-ytmnd="N" class="ytmnd-letter">n</span>ow we're eating goo<span data-ytmnd="D" class="ytmnd-letter">d</span> in the neighborhood.</p>
                <p class="text-micro">I want my baby back, baby back, baby back.</p>
              </p>
            </div>
          </section>

          <!-- Brian's Newest Friends -->
          <% if (latestUsers && latestUsers.length > 0) { %>
          <section class="myspace-section brispace-new-friends">
            <h3 style="margin-bottom: 0">Brian's newest friends</h3>
            <div class="brispace-friends-list">
              <% latestUsers.forEach(function(user) { %> <%- include('partials/user-display', {
              user: user }) %> <% }); %>
            </div>
            <div class="brispace-browse-link">
              <a href="/friends">Browse all &rarr;</a>
            </div>
          </section>
          <% } %>

                    <!-- Hero/Intro Section -->
          <section class="myspace-section">
            <h3 class="myspace-section-alt-header">but... why does this exist?</h3>
            <div class="brispace-intro-box">
              <p>What began as a simple way to share the details of my little 40th birthday trip,
                quickly snowballed into something larger, and a place where I found a lot of enjoyment in building a website in
                the spirit of the early internet. I had a blast looking back on these formative years and found lots of inspiration that
                spurred me on to create a space that hopefully captures the fun, creativity, and sense of community that defined the early
                 days of the web.
              </p>
              <p>BriSpace is a labor of love, a tribute to the past, and a celebration of the connections I've made in my life
                 all wrapped up in a little 2000's era bow. Whether you're here for the nostalgia, the memes, or just to say hi, I'm glad you found your way to BriSpace.
              </p>
              <p class="text-micro">I know there are bugs. Soooo many bugs.</p>
            </div>
          </section>
        </div>
        <!-- Login/Signup or Welcome -->
        <aside class="myspace-sidebar brispace-auth">
          <% if (!currentUser) { %>
          <div id="loginSignupContainer"></div>
          <% } else { %>
          <div class="login-signup-form">
            <h3>
              Welcome back,
              <%= currentUser.display_name || 'friend' %>!
            </h3>
            <a href="/users/<%= currentUser.username %>"
              >Go to your profile</a
            >
          </div>
          <% } %>
          <%- include('partials/sidebar-gif-stepper', { sidebarMedia: sidebarMedia, sidebarAdKeys: sidebarAdKeys, isSignedIn: isSignedIn }) %>
          <% if (sidebarTest && sidebarTest.enabled) { %>
          <div class="myspace-section" style="margin-top: 8px;">
            <h3 style="margin-bottom: 6px;">Sidebar Media Test</h3>
            <p style="margin: 0 0 8px 0; font-size: 11px;">
              Item <%= sidebarTest.index + 1 %> of <%= sidebarTest.total %>
            </p>
            <a class="btn btn--secondary" href="<%= sidebarTest.prevUrl %>">Prev</a>
            <a class="btn btn--primary" href="<%= sidebarTest.nextUrl %>">Next</a>
          </div>
          <% } %>
        </aside>
      </div>
    </main>
    <script type="module">
      import { createLoginSignupForm } from "/js/components/login-signup.js";
      import { BrispacePage } from "/js/pages/brispace.js";
      const page = new BrispacePage();
      await page.init();
      const isAuthenticated = document.body.dataset.auth === "true";
      if (!isAuthenticated) {
        const container = document.getElementById("loginSignupContainer");
        if (container) {
          const form = createLoginSignupForm({
            onSuccess: () => {
              window.location.href = "/";
            },
          });
          container.appendChild(form);
        }
      }
    </script>
    <% if (typeof isSignedIn !== 'undefined' && isSignedIn && typeof sidebarMedia !== 'undefined' && sidebarMedia && sidebarMedia.type === 'gif-stepper') { %>
    <script src="/js/components/gif-stepper.js"></script>
    <% } %>
  </body>
</html>
