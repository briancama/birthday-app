<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BriSpace - Friends</title>
    <link rel="icon" type="image/png" href="/images/favicon.jpg" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/myspace.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/brispace-home.css" />
    <link rel="stylesheet" href="/css/components/user-display.css" />
    <link rel="stylesheet" href="/css/components/login-signup.css" />
    <link rel="stylesheet" href="/css/components/submissions.css" />

    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
  </head>
  <body class="myspace" data-auth="<%= !!currentUser %>">
    <%- include('partials/navigation-visitor', { navData: (typeof navData !== 'undefined' ? navData
    : {}) }) %>
    <main class="myspace-container full-width-content">
      <div class="container myspace-layout">
        <div class="myspace-main">
          <section class="myspace-section">
            <h3 class="myspace-section-alt-header">BriSpace Friends</h3>
            <div class="brispace-intro-box">
              <p>
                All the <strong>fly peeps</strong> live here in Brispace. Complete your profile and
                you'll show up here too — customize your page, post your interests, and let people
                know who you are.
              </p>
            </div>
          </section>

          <section class="myspace-section brispace-new-friends">
            <h3 style="margin-bottom: 0">Published profiles</h3>
            <% if (allUsers && allUsers.length > 0) { %>
            <div class="brispace-friends-list">
              <% allUsers.forEach(function(user) { %> <%- include('partials/user-display', { user:
              user }) %> <% }); %>
            </div>
            <% } else { %>
            <p>No users found yet.</p>
            <% } %>
          </section>
        </div>

        <aside class="myspace-sidebar brispace-auth">
          <% if (!currentUser) { %>
          <div id="loginSignupContainer"></div>
          <% } else { %>
          <div class="login-signup-form">
            <h3>
              Welcome back,
              <%= currentUser.display_name || 'friend' %>!
            </h3>
            <a href="/users/<%= currentUser.username %>">Go to your profile</a>
          </div>
          <% } %>
          <%- include('partials/sidebar-scam-container', { hasSignedInUser: !!currentUser }) %>
        </aside>
      </div>
    </main>
    <script type="module">
      import { createLoginSignupForm } from "/js/components/login-signup.js";
      import { BrispacePage } from "/js/pages/brispace.js";
      const page = new BrispacePage();
      await page.init();
      const isAuthenticated = document.body.dataset.auth === "true";
      if (!isAuthenticated) {
        const container = document.getElementById("loginSignupContainer");
        if (container) {
          const form = createLoginSignupForm({
            onSuccess: () => {
              window.location.href = "/friends";
            },
          });
          container.appendChild(form);
        }
      } else {
        // Show the scam gif immediately — don't block on dialog imports
        const scamImg = document.getElementById("scamGif");
        const scamContainer = document.getElementById("scamGifContainer");
        if (scamImg && scamContainer) {
          const enableInteraction = () => {
            scamContainer.classList.remove("scam-hidden");
            scamContainer.classList.add("scam-visible");
          };
          if (scamImg.complete) {
            enableInteraction();
          } else {
            scamImg.addEventListener("load", enableInteraction, { once: true });
            setTimeout(enableInteraction, 2000);
          }
          scamImg.style.cursor = "pointer";
          // Lazy-load dialog chain only when user actually clicks
          scamImg.addEventListener("click", async (e) => {
            e.stopPropagation();
            const { DialogChain } = await import("/js/components/DialogChain.js");
            const { dialogChains } = await import("/js/components/dialog-chains.js");
            new DialogChain(dialogChains.scam).start();
          });
        }
      }
    </script>
  </body>
</html>
