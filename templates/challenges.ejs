<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Challenges - Birthday Challenge Zone</title>
    <link rel="icon" type="image/png" href="/images/favicon.jpg" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/submissions.css" />
    <link rel="stylesheet" href="/css/components/event-card.css" />
    <link rel="stylesheet" href="/css/components/character-select.css" />
    <!-- Firebase SDK -->
    <script defer src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script defer src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
  </head>

  <body class="has-bottom-menu">
    <% const navLocal = Object.assign({}, (typeof navData !== 'undefined' ? navData : {}), { pageTitle: 'My Challenges' }); %>
    <%- include('partials/navigation', { navData: navLocal }) %>

    <main>
      <section class="section">
        <h2>Complete Challenges</h2>
        <div id="challengesList" class="challenge-list" style="margin-bottom: 2rem">
          <% if (typeof eventStarted !== 'undefined' && !eventStarted) { %>
            <div class="feature-preview" style="text-align: center">
              <img style="margin-top: -25px" src="/images/construction.gif" alt="Under Construction" class="preview-gif" />
              <div style="text-align: left; padding: 1rem">
                <h3 style="margin-top: 0; text-align: center">What are Challenges?</h3>
                <p style="margin: 0.5rem 0">
                  Challenges are quick, fun activities that take <strong>30 seconds to 1 minute</strong> to complete. During the weekend, anyone can challenge you to perform one of these predetermined tasks—check the app and give it your best shot!
                </p>
                <p style="margin: 0.5rem 0">
                  <strong>Have an idea?</strong> We've got plenty of challenges already created, but feel free to submit your own! Whether it's a general challenge for anyone or a specific one tailored for a particular person,
                  <a href="/challenges-submit" style="color: #0000ff; text-decoration: underline">submit a challenge here</a>.
                </p>
                <p style="margin: 0.5rem 0; text-align: center; font-style: italic; font-size: 0.9rem">
                  Once the event starts, be ready to accept some challenges and climb the leaderboard!
                </p>
              </div>
            </div>
          <% } else if (typeof assignments !== 'undefined' && Array.isArray(assignments) && assignments.length > 0) { %>
            <%- include('partials/challenge-list', { assignments, options: getChallengeCardOptions({ challengesEnabled: typeof challengesEnabled !== 'undefined' ? challengesEnabled : true }) }) %>
          <% } %>
        </div>
        <script>
          window.__SERVER_ASSIGNMENTS__ = <%- typeof assignmentsJson !== 'undefined' ? assignmentsJson : '[]' %>;
          window.__EVENT_STARTED__ = <%= typeof eventStarted !== 'undefined' ? !!eventStarted : false %>;
        </script>
      </section>
      <section class="section section--character-select">
        <div class="character-select__intro-overlay">
          <div class="character-select__intro-inner">
            <p>
              Welcome to the Challenger Selection! Choose another challenger and hope they get the
              message and attempt to complete one of their challenges to earn points and climb the
              leaderboard. Each character has unique challenges, so pick wisely and get ready to
              watch them perform!
            </p>
            <button class="btn character-select__intro-start" data-no-sound>Start</button>
          </div>
        </div>
        <h2 class="character-select__title">Challenger Selection</h2>
        <div class="character-select__map-container">
          <img
            src="/images/street-fighter-map.png"
            alt="Street Fighter Map"
            class="character-select__map"
          />
        </div>
        <div id="characterSelectContainer"></div>
      </section>
    </main>

    <script type="module">
      import { ChallengesPage } from "/js/pages/challenges.js";

      const page = new ChallengesPage();
      window.addEventListener("DOMContentLoaded", () => page.init());
    </script>

    <bottom-menu></bottom-menu>
    <script type="module" src="/js/components/bottom-menu.js"></script>
  </body>
</html>
