<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Challenge Workshop - Brian's Birthday Zone</title>
    <link rel="icon" type="image/png" href="/images/favicon.jpg" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/leaderboard.css" />
    <link rel="stylesheet" href="/css/components/submissions.css" />
    <link rel="stylesheet" href="/css/components/forms.css" />
    <!-- Firebase SDK -->
    <script defer src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script defer src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
  </head>
  <body class="has-bottom-menu">
    <% const navLocal = Object.assign({}, (typeof navData !== 'undefined' ? navData : {}), {
    pageTitle: 'Workshop' }); %> <%- include('partials/navigation', { navData: navLocal }) %>

    <div class="container">
      <div class="flame-divider scam-hidden" id="scamGifContainer">
        <img
          id="scamGif"
          class="clickable"
          src="/images/scam.gif"
          alt="definitely a scam add"
          class="divider-gif"
        />
      </div>
      <div class="section">
        <button id="addChallengeBtn" class="add-challenge-btn">✨ ADD CHALLENGE ✨</button>
        <!-- Retro collapsible details for challenge info -->
        <details class="challenge-info-details" style="margin: 1rem 0">
          <summary
            class="challenge-info-summary"
            style="cursor: pointer; font-weight: bold; font-size: 1.1rem"
          >
            <img
              src="/images/question.gif"
              alt="?"
              class="icon-gif"
              style="vertical-align: middle; margin-right: 6px"
            />
            What are Challenges?
          </summary>
          <div class="challenge-info-content" style="padding: 1rem 0 0 0">
            <p style="margin: 0.5rem 0">
              Challenges are quick, fun activities that take
              <strong>30 seconds to 1 minute</strong> to complete. During the weekend, anyone can
              challenge you to perform one of these predetermined tasks—check the app and give it
              your best shot!
            </p>
            <p style="margin: 0.5rem 0">
              <strong>Have an idea?</strong> I've got plenty of challenges already created, but feel
              free to submit your own! Whether it's a general challenge for anyone or a specific one
              tailored for a particular person, you can add your challenge from this page.
            </p>
            <p style="margin: 0.5rem 0">
              <strong>What is Brian Mode?</strong> Some challenges can be marked as
              <span style="color: #cc00cc; font-weight: bold">Brian Mode</span>! If you select
              <b>VS Brian</b>, Brian will be assigned the challenge as your rival—if you succeed, he
              must fail (and vice versa). If you select <b>WITH Brian</b>, Brian will be assigned a
              cooperative challenge and you’ll both try to complete it together. Look, I love a
              little competition and might just be looking for a few extra points to pad my
              stats.<img
                src="images/silly.gif"
                alt="wink"
                class="icon-gif"
                class="icon-gif icon-gif--with-text"
              />
            </p>
            <p style="margin: 0.5rem 0; font-style: italic; font-size: 0.9rem; text-align: center">
              Once the event starts, be ready to accept some challenges and climb the leaderboard!
            </p>
          </div>
        </details>
        <h2 class="text-shadow-light">Your Submitted Challenges</h2>
        <div id="submissionsContainer">
          <div class="empty-state">Loading your submissions...</div>
        </div>
      </div>
    </div>

    <!-- Challenge Submission Modal -->
    <div id="challengeModal" class="challenge-modal" style="display: none">
      <div class="challenge-modal-overlay"></div>
      <div class="challenge-modal-content">
        <button id="closeChallengeModal" class="close-btn">✖️</button>

        <h2 class="text-center rainbow-text">NEW CHALLENGE!</h2>

        <form id="challengeForm">
          <div class="form-group">
            <label for="challengeName">Challenge Name *</label>
            <input type="text" id="challengeName" required maxlength="100" />
            <small>Max 100 characters</small>
          </div>

          <div class="form-group">
            <label for="challengeDescription">Challenge Description *</label>
            <textarea id="challengeDescription" required maxlength="500"></textarea>
            <small>Max 500 characters. Describe what needs to be done.</small>
          </div>

          <div class="form-group">
            <label for="challengeMetric">Success Metric (Optional)</label>
            <input type="text" id="challengeMetric" maxlength="200" />
            <small
              >Max 200 characters. How will success be measured? Leave blank if not
              applicable.</small
            >
          </div>

          <div class="form-group" id="brianModeGroup">
            <label for="brianMode">Brian Participation (Optional)</label>
            <select id="brianMode">
              <option value="" selected>None (Regular Challenge)</option>
              <option value="vs">⚔️ VS Brian (Competitive)</option>
              <option value="with">🤝 WITH Brian (Collaborative)</option>
            </select>
            <small
              ><strong>VS:</strong> Brian must fail if you succeed (and vice versa) •
              <strong>WITH:</strong> Brian must complete the same challenge as you</small
            >
          </div>

          <div class="form-group">
            <label for="assignedTo">Suggest For (Optional)</label>
            <input
              type="text"
              id="assignedTo"
              list="usersDatalist"
              placeholder="Start typing a username..."
            />
            <datalist id="usersDatalist"></datalist>
            <small>Leave blank for anyone to accept, or suggest for a specific user.</small>
          </div>

          <button type="submit" id="submitChallengeBtn">🚀 SUBMIT CHALLENGE 🚀</button>

          <div id="formError" class="error-message"></div>
          <div id="formSuccess" class="success-message"></div>
        </form>
      </div>
    </div>

    <script type="module">
      import { appState } from "/js/app.js";
      import { ChallengesSubmitPage } from "/js/pages/challenges-submit.js";

      const page = new ChallengesSubmitPage();
      page.init();
    </script>
    <bottom-menu></bottom-menu>
    <script type="module" src="/js/components/bottom-menu.js"></script>
  </body>
</html>
