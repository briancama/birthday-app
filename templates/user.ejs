<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title><%= user.display_name ? user.display_name + ' — BriSpace' : 'BriSpace' %></title>
    <link rel="icon" type="image/png" href="/images/brispace_favicon.png" />
    <link rel="stylesheet" href="/css/geocities.css" />
    <link rel="stylesheet" href="/css/components/navigation.css" />
    <link rel="stylesheet" href="/css/components/myspace.css" />
    <link rel="stylesheet" href="/css/components/myspace-comments.css" />
    <link rel="stylesheet" href="/css/components/user-profile.css" />
    <link rel="stylesheet" href="/css/components/secret-player.css" />
    <link rel="preload" as="image" href="<%= user.headshot || '/images/headshot.jpg' %>" />
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.2/firebase-auth-compat.js"></script>
    <!-- DOMPurify for client-side HTML sanitization -->
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js"></script>
    <!-- Quill WYSIWYG editor -->
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <% if (user.profile_bg_url) { %>
    <style>
      body.myspace {
        background-image: url('<%= user.profile_bg_url %>');
        background-repeat: <%= user.profile_bg_mode === 'tile' ? 'repeat' : 'no-repeat' %>;
        background-size: <%= user.profile_bg_mode === 'cover' ? 'cover' : 'auto' %>;
      }
    </style>
    <% } %>
  </head>

  <body class="myspace has-bottom-menu" data-profile-user-id="<%= user.id %>">
    <!-- Server-rendered navigation header -->
    <%- include('partials/navigation', { navData: navData }) %>

    <!-- ── Main layout ─────────────────────────────────────────── -->
    <div class="myspace-container full-width-content">
      <div class="container myspace-layout">
        <!-- ── Sidebar ──────────────────────────────────────────── -->
        <aside class="myspace-sidebar">
          <!-- Name + headshot -->
          <div class="myspace-section profile-section">
            <h2 class="myspace-name">
              <%= profile_title || (user.display_name ? user.display_name + "'s BriSpace" :
              "BriSpace") %>
            </h2>
            <div class="myspace-profile-row">
              <div class="myspace-headshot-container">
                <img
                  src="<%= user.headshot || '/images/headshot.jpg' %>"
                  alt="Profile headshot"
                  class="myspace-headshot"
                  data-headshot="user-profile"
                />
                <!-- Add User to top 8 -->
                <% if (typeof isOwnProfile !== 'undefined' && !isOwnProfile && typeof isInTopN !== 'undefined' && !isInTopN) { %>
                  <button id="add-to-topn-btn" class="btn btn--primary">Add to my Top 8</button>
                <% } %>
              </div>
              <div class="myspace-about">
                <p class="profile-status-text" data-display="status">
                  <%= user.status ? '"' + user.status + '"' : '—' %>
                </p>
                <p class="profile-location" data-display="hometown">
                  <%= user.hometown || 'Somewhere, Somewhere' %>
                </p>
                <p class="profile-age" data-display="age">
                  <%= user.age ? user.age + ' yrs old' : '—' %>
                </p>
                <div id="headshotUploadContainer">
                  <p class="myspace-about__hint">
                    Upload a <strong>vintage 2000s photo</strong> of yourself.
                  </p>
                </div>
              </div>
            </div>
            <!-- Challenge button removed: replaced by Top 8 and publish profile features -->
            <button id="edit-profile-btn" class="profile-edit-btn profile-edit-btn--below">
              ✏ edit
            </button>
            <form id="edit-profile-form" class="profile-edit-form profile-edit-form--modal">
              <label
                >Status<input
                  type="text"
                  data-field="status"
                  placeholder="What's on your mind?"
                  value="<%= user.status || '' %>"
                  maxlength="200"
              /></label>
              <label
                >Hometown<input
                  type="text"
                  data-field="hometown"
                  placeholder="City, State"
                  value="<%= user.hometown || '' %>"
                  maxlength="100"
              /></label>
              <label
                >Age<input
                  type="number"
                  data-field="age"
                  placeholder="e.g. 30"
                  value="<%= user.age || '' %>"
                  min="1"
                  max="149"
              /></label>
              <div class="profile-edit-actions">
                <button type="button" class="profile-edit-save">Save</button>
                <button type="button" class="profile-edit-cancel">Cancel</button>
              </div>
            </form>
          </div>
          <!-- User Publish Toggle -->
          <% if (typeof isOwnProfile !== 'undefined' && isOwnProfile) { %>
            <div class="profile-publish-toggle-standalone">
              <label class="profile-publish-toggle">
                <input type="checkbox" id="publish-profile-toggle" data-field="is_published" <%= user.is_published ? 'checked' : '' %> />
                <span>Publish my profile (visible to others)</span>
              </label>
            </div>
          <% } %>
          <section class="event-details-card myspace-section profile-section">
            <div class="event-details-header">
              <%= profile_title || (user.display_name ? user.display_name + "'s Interests" :
              "Interests") %>
            </div>
            <button id="edit-interests-btn" class="profile-edit-btn profile-edit-btn--below">
              ✏ edit
            </button>
            <div class="event-details-list">
              <div class="event-details-row">
                <div class="event-details-label">General</div>
                <div class="event-details-value" data-display="general_interest">
                  <%= user.general_interest || '—' %>
                </div>
              </div>
              <div class="event-details-row">
                <div class="event-details-label">Music</div>
                <div class="event-details-value" data-display="fav_song">
                  <%= user.fav_song || '—' %>
                </div>
              </div>
              <div class="event-details-row">
                <div class="event-details-label">Movies</div>
                <div class="event-details-value" data-display="fav_movie">
                  <%= user.fav_movie || '—' %>
                </div>
              </div>
              <div class="event-details-row">
                <div class="event-details-label">Television</div>
                <div class="event-details-value" data-display="television">
                  <%= user.television || '—' %>
                </div>
              </div>
            </div>

            <!-- Interests edit form (owner only, toggled) -->
            <form id="edit-interests-form" class="profile-edit-form profile-edit-form--modal">
              <textarea data-field="general_interest" placeholder="Life, Family, Career">
<%= user.general_interest || '' %></textarea
              >
              <textarea data-field="fav_movie" placeholder="My Movies">
<%= user.fav_movie || '' %></textarea
              >
              <textarea data-field="fav_song" placeholder="My Music">
<%= user.fav_song || '' %></textarea
              >
              <textarea data-field="television" placeholder="My TV Shows">
<%= user.television || '' %></textarea
              >
              <div class="profile-edit-actions">
                <button type="button" class="profile-edit-save">Save</button>
                <button type="button" class="profile-edit-cancel">Cancel</button>
              </div>
            </form>
          </section>

          <!-- Music player placeholder -->
          <div class="myspace-section" id="musicPlayerContainer"></div>

          <!-- Gif stepper -->
          <div class="myspace-section">
            <img
              class="myspace-section-gif"
              src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
              data-src="/images/iron-man.gif"
              width="347"
              height="207"
              data-gif-stepper
              data-gif-sound="proton-cannon.mp3"
              data-gif-sound-percent="70"
              data-steps-per-click="3"
            />
          </div>
        </aside>

        <!-- ── Main column ───────────────────────────────────────── -->
        <main class="myspace-main">
          <!-- About Me -->
          <div class="myspace-section profile-section">
            <h3>About Me</h3>
            <button class="profile-edit-btn profile-edit-btn--below" id="edit-bio-btn">
              ✏ edit
            </button>
            <div class="profile-about-content" id="bio-display">
              <% if (user.about_html) { %>
                <%- user.about_html %>
              <% } else { %>
                <p class="profile-status-text">Nothing here yet.</p>
              <% } %>
            </div>
            <div class="profile-edit-form" id="edit-bio-form" data-quill-form>
              <div id="bio-quill-editor"></div>
              <!-- Hidden field read by _saveSection -->
              <textarea data-field="about_html" style="display: none">
<%= user.about_html || '' %></textarea
              >
              <div class="profile-edit-actions">
                <button class="profile-edit-save">Save</button>
                <button class="profile-edit-cancel">Cancel</button>
              </div>
            </div>
          </div>

          <!-- Achievements -->
          <div class="myspace-section">
            <h3>Achievements</h3>
            <div
              class="achievements-strip<% if (typeof userAchievements !== 'undefined' && userAchievements.length > 0) { %> server-rendered<% } %>"
              id="achievements-container"
            >
              <% if (typeof userAchievements !== 'undefined' && userAchievements.length > 0) { %>
              <% userAchievements.forEach(function(ua) { %>
              <% const ach = ua.achievements || {}; %>
              <div class="achievement-badge" title="<%= ach.name || '' %>">
                <img
                  src="<%= ach.image_url || '/images/star_icon.gif' %>"
                  alt="<%= (ach.description || '').replace(/\"/g, '&quot;') %>"
                />
                <span class="achievement-badge__name"><%= ach.name || '' %></span>
              </div>
              <% }); %>
              <% } else { %>
              <p class="achievements-empty">No achievements yet. Check back soon!</p>
              <% } %>
            </div>
          </div>

          <!-- Profile Wall -->
          <div class="myspace-section myspace-guestbook">
            <h3>Wall</h3>
            <div class="profile-wall-entries myspace-comments-list" id="wall-entries">
              <p>Loading...</p>
            </div>
            <div id="wall-post-form" class="wall-post-form">
              <textarea placeholder="Leave a comment..." maxlength="500"></textarea>
              <button class="wall-post-btn">Post</button>
            </div>
          </div>

          <!-- Top N -->
          <div class="myspace-section profile-section">
            <h3>Brian's Friends</h3>
            <div class="top-n-header">
              Brian has
              <span class="top-n-count"><%= userCount %></span>
              friend<%= userCount === 1 ? '' : 's' %>.
            </div>
            <div class="top-n-grid" id="topn-display">
              <% allUsers = (typeof allUsers !== 'undefined' ? allUsers : []); %> <% if
              (allUsers.length > 0) { %>
              <% allUsers.forEach(function(user, i) { %>
              <div class="top-n-item">
                <a href="/users/<%= user.id %>" class="top-n-item__link">
                  <span class="top-n-item__label"><%- user.display_name %></span>
                  <img
                    class="top-n-item__image"
                    src="<%= user.headshot || '/images/headshot.jpg' %>"
                    alt="<%- user.display_name %> headshot"
                    class="top-n-item__headshot"
                  />
                </a>
              </div>
              <% }); %>
              <% } else { %>
              <p class="top-n-empty">No users found.</p>
              <% } %>
            </div>
          </div>
        </main>
      </div>
    </div>

    <script src="/js/components/gif-stepper.js"></script>
    <script type="module">
      import { UserProfilePage } from "/js/pages/user-profile.js";

      const page = new UserProfilePage();
      window.addEventListener("DOMContentLoaded", () => page.init());
    </script>

    <bottom-menu></bottom-menu>
    <script type="module" src="/js/components/bottom-menu.js"></script>
  </body>
</html>
